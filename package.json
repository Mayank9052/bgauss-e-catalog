{
  "name": "bgauss-orchestrator",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "api": "dotnet run --project BGAUSS.Api",
    "client": "cd vite-project && npm run dev",
    "dev-all": "concurrently -k -n API,CLIENT \"npm run api\" \"wait-on tcp:5053 && npm run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.39.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "jwt-decode": "^4.0.0",
    "react-medium-image-zoom": "^5.4.1",
    "react-router-dom": "^7.13.1",
    "react-zoom-pan-pinch": "^3.7.0"
  }
}
